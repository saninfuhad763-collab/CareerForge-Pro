# Port for the Express API Server
PORT=5000

# Connection URI for the MongoDB database (Use local or remote fallback)
MONGODB_URI=mongodb://127.0.0.1:27017/careerforge-pro

# Secret key used for signing JSON Web Tokens (JWT)
# WARNING: Change this key to a secure, randomly generated string in production environments!
JWT_SECRET=your_jwt_secret_key_here

# Runtime Environment mode
NODE_ENV=development
