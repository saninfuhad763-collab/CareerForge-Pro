# Port for the Express API Server
PORT=5000

# Connection URI for the MongoDB database (Use local or remote fallback)
MONGODB_URI=mongodb://127.0.0.1:27017/careerforge-pro

# Secret key used for signing JSON Web Tokens (JWT)
# WARNING: Change this key to a secure, randomly generated string in production environments!
JWT_SECRET=your_jwt_secret_key_here

# Runtime Environment mode
NODE_ENV=development

# Frontend URL used for Stripe redirect URLs and CORS
CLIENT_URL=http://localhost:5173

# Groq AI (Week 2)
GROQ_API_KEY=your_groq_api_key_here
GROQ_MODEL=llama-3.3-70b-versatile

# Puppeteer / Chrome path for PDF generation (optional — auto-detected if omitted)
# PUPPETEER_EXECUTABLE_PATH=C:\Program Files\Google\Chrome\Application\chrome.exe

# Stripe Billing (Week 3)
STRIPE_SECRET_KEY=sk_test_your_stripe_secret_key
STRIPE_WEBHOOK_SECRET=whsec_your_webhook_signing_secret
STRIPE_PRICE_ID=price_your_pro_subscription_price_id
